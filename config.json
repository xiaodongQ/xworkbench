{
  "default_terminal": "wezterm",
  "preferred_cli": "claude",
  "ai_loop_enabled": false,
  "aichat_default_cli": "claude",
  "todo_md_path": "/tmp/todo-final.md",
  "scheduler_enabled": false,
  "relay": {
    "api_key": "xworkbench"
  },
  "terminal": {
    "detect_paths": {
      "wezterm": [
        "/Applications/WezTerm.app/Contents/MacOS/WezTerm"
      ]
    },
    "types": {
      "cmd": {
        "bin": "cmd.exe",
        "args": [
          "/K",
          "cd /d {dir}"
        ],
        "name": "CMD",
        "plate": "Windows",
        "path": ""
      },
      "gnome": {
        "bin": "gnome-terminal",
        "args": [
          "--",
          "--working-directory={dir}"
        ],
        "name": "GNOME Terminal",
        "plate": "linux",
        "path": ""
      },
      "powershell": {
        "bin": "powershell.exe",
        "args": [
          "-NoExit",
          "-c",
          "cd '{dir}'"
        ],
        "name": "PowerShell",
        "plate": "Windows",
        "path": ""
      },
      "pwsh": {
        "bin": "pwsh.exe",
        "args": [
          "-NoExit",
          "-c",
          "cd '{dir}'"
        ],
        "name": "PowerShell Core",
        "plate": "all",
        "path": ""
      },
      "pwsh7": {
        "bin": "pwsh",
        "args": [
          "-NoExit",
          "-c",
          "cd '{dir}'"
        ],
        "name": "PowerShell 7",
        "plate": "all",
        "path": ""
      },
      "terminal": {
        "bin": "osascript",
        "args": [
          "-e",
          "tell application \"Terminal\" to do script \"cd '{dir}'\""
        ],
        "name": "Terminal.app",
        "plate": "macOS",
        "path": "/usr/bin/osascript"
      },
      "wezterm": {
        "bin": "wezterm",
        "args": [
          "start",
          "--cwd",
          "{dir}",
          "--always-new-process"
        ],
        "name": "WezTerm",
        "plate": "all",
        "path": "/Applications/WezTerm.app/Contents/MacOS/WezTerm"
      },
      "wt": {
        "bin": "wt.exe",
        "args": [
          "-d",
          "{dir}"
        ],
        "name": "Windows Terminal",
        "plate": "Windows",
        "path": ""
      },
      "xterm": {
        "bin": "xterm",
        "args": [
          "-e",
          "bash -c 'cd {dir}; exec bash'"
        ],
        "name": "xterm",
        "plate": "linux",
        "path": ""
      }
    }
  },
  "models": {
    "cbc": {
      "default": "glm-4.7",
      "options": [
        {
          "value": "glm-5.1",
          "label": "GLM-5.1（x1.06）"
        },
        {
          "value": "glm-5.0",
          "label": "GLM-5.0（x0.80）"
        },
        {
          "value": "glm-5.0-turbo",
          "label": "GLM-5.0-Turbo（x0.95）"
        },
        {
          "value": "glm-5v-turbo",
          "label": "GLM-5v-Turbo（x0.95）"
        },
        {
          "value": "glm-4.7",
          "label": "GLM-4.7（x0.23）"
        },
        {
          "value": "minimax-m3",
          "label": "MiniMax-M3（x0.25）"
        },
        {
          "value": "minimax-m2.7",
          "label": "MiniMax-M2.7（x0.26）"
        },
        {
          "value": "kimi-k2.6",
          "label": "Kimi-K2.6（x0.59）"
        },
        {
          "value": "kimi-k2.5",
          "label": "Kimi-K2.5（x0.45）"
        },
        {
          "value": "hy3-preview",
          "label": "Hy3 preview（x0.37）"
        },
        {
          "value": "deepseek-v4-pro",
          "label": "Deepseek-V4-Pro（x0.25）"
        },
        {
          "value": "deepseek-v4-flash",
          "label": "Deepseek-V4-Flash（x0.13）"
        },
        {
          "value": "deepseek-v3-2-volc",
          "label": "DeepSeek-V3.2（x0.29）"
        }
      ]
    },
    "claude": {
      "default": "sonnet",
      "options": [
        {
          "value": "haiku",
          "label": "haiku（快+便宜）"
        },
        {
          "value": "sonnet",
          "label": "sonnet（推荐 · 准确）"
        },
        {
          "value": "opus",
          "label": "opus（最强 · 贵）"
        }
      ]
    }
  }
}