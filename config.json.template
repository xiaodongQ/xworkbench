{
  "_comment": "xworkbench 配置模板。复制成 config.json 后按需修改。本文件随仓库分发，config.json 本身在 .gitignore。字段说明见 README.md「配置」章节。",
  "default_terminal": "wezterm",
  "preferred_cli": "claude",
  "ai_loop_enabled": false,
  "aichat_default_cli": "claude",
  "dangerously_skip_permissions": false,
  "todo_md_path": "",
  "scheduler_enabled": false,
  "relay": {
    "_comment": "代理接口认证 token。空=关闭认证（仅本机）。非空=Bearer token（也支持 X-API-Key 头）。生产环境请改成一个长随机串。",
    "api_key": "xworkbench"
  },
  "terminal": {
    "_comment": "终端类型定义 + 检测路径。types 新增自定义终端时按现有 schema 加；{dir} 占位符会被替换为打开目录的绝对路径。",
    "detect_paths": {
      "wezterm": [
        "/Applications/WezTerm.app/Contents/MacOS/WezTerm"
      ]
    },
    "types": {
      "wezterm":    {"bin": "wezterm",    "args": ["start", "--cwd", "{dir}", "--always-new-process"],  "name": "WezTerm",          "plate": "all",      "path": ""},
      "wt":         {"bin": "wt.exe",     "args": ["-d", "{dir}"],                                       "name": "Windows Terminal","plate": "windows",  "path": ""},
      "powershell": {"bin": "powershell.exe", "args": ["-NoExit", "-Command", "cd \"{dir}\""],            "name": "PowerShell",       "plate": "windows",  "path": ""},
      "pwsh":       {"bin": "pwsh.exe",   "args": ["-NoExit", "-Command", "cd \"{dir}\""],               "name": "PowerShell Core",  "plate": "windows",  "path": ""},
      "pwsh7":      {"bin": "pwsh",       "args": ["-NoExit", "-c", "cd '{dir}'"],                       "name": "PowerShell 7",     "plate": "all",      "path": ""},
      "iterm2":     {"bin": "osascript",   "args": ["-e", "tell application \"iTerm2\" to create window with default profile"], "name": "iTerm2",          "plate": "darwin",   "path": ""},
      "terminal":   {"bin": "osascript",   "args": ["-e", "tell application \"Terminal\" to do script \"cd {dir}\""], "name": "Terminal.app", "plate": "darwin", "path": ""},
      "gnome":      {"bin": "gnome-terminal", "args": ["--", "--working-directory={dir}"],              "name": "GNOME Terminal",   "plate": "linux",    "path": ""},
      "xterm":      {"bin": "xterm",       "args": ["-e", "bash -c 'cd {dir}; exec bash'"],              "name": "xterm",             "plate": "linux",    "path": ""},
      "cmd":        {"bin": "cmd.exe",     "args": ["/K", "cd /d {dir}"],                                 "name": "cmd.exe",           "plate": "windows",  "path": ""}
    }
  },
  "models": {
    "_comment": "key=cli_type (claude / cbc)，value=该 CLI 的模型配置。default=任务执行默认；eval_default=AI 评估员默认（独立于 default）。新增模型时同时填 default/eval_default/options。",
    "claude": {
      "default": "sonnet",
      "eval_default": "haiku",
      "options": [
        {"value": "haiku",  "label": "haiku（快+便宜）"},
        {"value": "sonnet", "label": "sonnet（推荐 · 准确）"},
        {"value": "opus",   "label": "opus（最强 · 贵）"}
      ]
    },
    "cbc": {
      "default": "glm-4.7",
      "eval_default": "deepseek-v4-pro",
      "options": [
        {"value": "glm-5.1",          "label": "GLM-5.1（x1.06）"},
        {"value": "glm-5.0",          "label": "GLM-5.0（x0.80）"},
        {"value": "glm-5.0-turbo",    "label": "GLM-5.0-Turbo（x0.95）"},
        {"value": "glm-5v-turbo",     "label": "GLM-5v-Turbo（x0.95）"},
        {"value": "glm-4.7",          "label": "GLM-4.7（x0.23）"},
        {"value": "minimax-m3",       "label": "MiniMax-M3（x0.25）"},
        {"value": "minimax-m2.7",     "label": "MiniMax-M2.7（x0.26）"},
        {"value": "kimi-k2.6",        "label": "Kimi-K2.6（x0.59）"},
        {"value": "kimi-k2.5",        "label": "Kimi-K2.5（x0.45）"},
        {"value": "hy3-preview",      "label": "Hy3 preview（x0.37）"},
        {"value": "deepseek-v4-pro",  "label": "Deepseek-V4-Pro（x0.25）"},
        {"value": "deepseek-v4-flash","label": "Deepseek-V4-Flash（x0.13）"},
        {"value": "deepseek-v3-2-volc","label": "DeepSeek-V3.2（x0.29）"}
      ]
    }
  },
  "ssh": {
    "_comment": "SSH 密钥全局配置。default_key_path 为默认私钥路径，单个远程目录可覆盖。",
    "default_key_path": ""
  },
  "ai_chat": {
    "_comment": "AI Chat 对话配置（Anthropic / OpenAI 双 Provider 共存）。active_provider 为当前激活的 provider（openai | anthropic）。",
    "active_provider": "anthropic",
    "anthropic": {
      "api_key": "",
      "base_url": "",
      "model": "",
      "temperature": 0.7,
      "max_tokens": 4096
    },
    "openai": {
      "api_key": "",
      "base_url": "",
      "model": "",
      "temperature": 0.7,
      "max_tokens": 4096
    },
    "system_prompt": ""
  }
}
