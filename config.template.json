{
  "default_terminal": "wezterm",
  "preferred_cli": "claude",
  "ai_loop_enabled": false,
  "aichat_default_cli": "claude",
  "dangerously_skip_permissions": false,
  "todo_md_path": "/tmp/todo-final.md",
  "scheduler_enabled": true,

  "relay": {
    "api_key": "xworkbench"
  },

  "ssh": {
    "default_key_path": "",
    "compat_algorithms": {
      "kex":      ["+diffie-hellman-group1-sha1", "+diffie-hellman-group-exchange-sha1"],
      "host_key": ["+ssh-rsa", "+ssh-dss"],
      "cipher":   ["+3des-cbc", "+aes128-cbc", "+aes192-cbc", "+aes256-cbc"]
    }
  },

  "terminal": {
    "detect_paths": {
      "wezterm": ["/Applications/WezTerm.app/Contents/MacOS/WezTerm"]
    },
    "types": {
      "wezterm": {
        "bin": "wezterm",
        "args": ["start", "--cwd", "{dir}", "--always-new-process"],
        "remote_args": ["ssh", "-i", "{key_path}", "{user}@{host}", "-t", "--", "sh", "-c", "{shell_cmd}"],
        "name": "WezTerm",
        "plate": "all",
        "path": "/Applications/WezTerm.app/Contents/MacOS/WezTerm"
      },
      "wt": {
        "bin": "wt.exe",
        "args": ["-d", "{dir}"],
        "remote_args": ["ssh", "-i", "{key_path}", "{user}@{host}"],
        "name": "Windows Terminal",
        "plate": "Windows",
        "path": ""
      },
      "powershell": {
        "bin": "powershell.exe",
        "args": ["-NoExit", "-c", "cd '{dir}'"],
        "remote_args": ["ssh", "-i", "{key_path}", "{user}@{host}"],
        "name": "PowerShell",
        "plate": "Windows",
        "path": ""
      },
      "pwsh": {
        "bin": "pwsh.exe",
        "args": ["-NoExit", "-c", "cd '{dir}'"],
        "remote_args": ["ssh", "-i", "{key_path}", "{user}@{host}"],
        "name": "PowerShell Core",
        "plate": "Windows",
        "path": ""
      },
      "pwsh7": {
        "bin": "pwsh",
        "args": ["-NoExit", "-c", "cd '{dir}'"],
        "remote_args": ["ssh", "-i", "{key_path}", "{user}@{host}"],
        "name": "PowerShell 7",
        "plate": "all",
        "path": ""
      },
      "iterm2": {
        "bin": "osascript",
        "args": ["-e", "tell application \"iTerm2\" to create window with default profile"],
        "remote_args": ["ssh", "-i", "{key_path}", "{user}@{host}"],
        "name": "iTerm2",
        "plate": "darwin",
        "path": ""
      },
      "terminal": {
        "bin": "osascript",
        "args": ["-e", "tell application \"Terminal\" to do script \"cd '{dir}'\""],
        "remote_args": ["ssh", "-i", "{key_path}", "{user}@{host}"],
        "name": "Terminal.app",
        "plate": "macOS",
        "path": "/usr/bin/osascript"
      },
      "gnome": {
        "bin": "gnome-terminal",
        "args": ["--", "--working-directory={dir}"],
        "remote_args": ["ssh", "-i", "{key_path}", "{user}@{host}"],
        "name": "GNOME Terminal",
        "plate": "linux",
        "path": ""
      },
      "xterm": {
        "bin": "xterm",
        "args": ["-e", "bash -c 'cd {dir}; exec bash'"],
        "remote_args": ["ssh", "-i", "{key_path}", "{user}@{host}"],
        "name": "xterm",
        "plate": "linux",
        "path": ""
      },
      "cmd": {
        "bin": "cmd.exe",
        "args": ["/K", "cd /d {dir}"],
        "remote_args": ["ssh", "-i", "{key_path}", "{user}@{host}"],
        "name": "CMD",
        "plate": "Windows",
        "path": ""
      }
    }
  },

  "models": {
    "claude": {
      "default": "sonnet",
      "eval_default": "sonnet",
      "options": [
        {"value": "haiku", "label": "haiku（快+便宜）"},
        {"value": "sonnet", "label": "sonnet（推荐 · 准确）"},
        {"value": "opus", "label": "opus（最强 · 贵）"}
      ]
    },
    "cbc": {
      "default": "deepseek-v4-pro",
      "eval_default": "kimi-k2.6",
      "options": [
        {"value": "glm-5.1", "label": "GLM-5.1（x1.06）"},
        {"value": "glm-5.0", "label": "GLM-5.0（x0.80）"},
        {"value": "glm-5.0-turbo", "label": "GLM-5.0-Turbo（x0.95）"},
        {"value": "glm-5v-turbo", "label": "GLM-5v-Turbo（x0.95）"},
        {"value": "glm-4.7", "label": "GLM-4.7（x0.23）"},
        {"value": "minimax-m3", "label": "MiniMax-M3（x0.25）"},
        {"value": "minimax-m2.7", "label": "MiniMax-M2.7（x0.26）"},
        {"value": "kimi-k2.6", "label": "Kimi-K2.6（x0.59）"},
        {"value": "kimi-k2.5", "label": "Kimi-K2.5（x0.45）"},
        {"value": "hy3-preview", "label": "Hy3 preview（x0.37）"},
        {"value": "deepseek-v4-pro", "label": "Deepseek-V4-Pro（x0.25）"},
        {"value": "deepseek-v4-flash", "label": "Deepseek-V4-Flash（x0.13）"},
        {"value": "deepseek-v3-2-volc", "label": "DeepSeek-V3.2（x0.29）"}
      ]
    }
  },

  "ai_chat": {
    "active_provider": "anthropic",
    "anthropic": {
      "api_key": "",
      "base_url": "https://api.anthropic.com",
      "model": "claude-3-5-sonnet-20241022",
      "temperature": 0.7,
      "max_tokens": 4096
    },
    "openai": {
      "api_key": "",
      "base_url": "https://api.openai.com/v1",
      "model": "gpt-4o",
      "temperature": 0.7,
      "max_tokens": 4096
    },
    "system_prompt": ""
  },

  "scheduler": {
    "max_resume_count": 20
  }
}
